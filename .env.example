# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Notes ────────────────────────────────────────────────────────────────────
# 1. Copy this file to .env.local (never commit .env.local)
# 2. Replace the values above with your actual Supabase project credentials
# 3. Run the SQL in supabase/schema.sql in your Supabase SQL Editor
# 4. Deploy to Vercel and add both vars under Project > Settings > Environment Variables
