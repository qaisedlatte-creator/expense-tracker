# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── AI Chatbot ───────────────────────────────────────────────────────────────
# Get this from: https://console.anthropic.com/settings/keys
# Add to Vercel: Project > Settings > Environment Variables

ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Notes ────────────────────────────────────────────────────────────────────
# 1. Copy this file to .env.local (never commit .env.local)
# 2. Fill in NEXT_PUBLIC_SUPABASE_URL + NEXT_PUBLIC_SUPABASE_ANON_KEY
# 3. Fill in ANTHROPIC_API_KEY for the AI chat feature
# 4. Run supabase/schema.sql (+ schema-chat.sql) in your Supabase SQL Editor
# 5. Deploy to Vercel and add all vars under Project > Settings > Environment Variables
